{
       "$schema": "http://json-schema.org/draft-07/schema",
       "type": "object",
       "anyOf": [
              {
                     "$ref": "#/definitions/mobidp.adapters.String"
              },
              {
                     "$ref": "#/definitions/mobidp.adapters.Duration"
              }
       ],
       "definitions": {
              "mobidp.common.String": {
                     "type": "string"
              },
              "mobidp.common.Duration": {
                     "type": [
                            "number",
                            "string"
                     ],
                     "pattern": "^P([0-9]+D)?([0-9]+H)?([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?$"
              },
              "Foo": {
                     "type": "object",
                     "properties": {
                            "a": {
                                   "type": "string"
                            },
                            "b": {
                                   "type": "number"
                            }
                     }
              },
              "Bar": {
                     "type": "object",
                     "allOf": [
                            {
                                   "$ref": "#/definitions/Foo"
                            }
                     ],
                     "properties": {
                            "c": {
                                   "$ref": "#/definitions/mobidp.adapters.Duration"
                            }
                     }
              },
              "Baz": {
                     "type": "array",
                     "items": {
                            "type": "object",
                            "additionalProperties": {
                                   "$ref": "#/definitions/mobidp.common.String"
                            }
                     }
              }
       }
}
