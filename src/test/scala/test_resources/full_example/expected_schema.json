{
       "$schema": "http://json-schema.org/draft-07/schema",
       "type": "object",
       "anyOf": [
              {
                     "$ref": "#/definitions/mobidp.adapters.String"
              },
              {
                     "$ref": "#/definitions/mobidp.adapters.Duration"
              }
       ],
       "definitions": {
              "mobidp.common.String": {
                     "type": "string"
              },
              "mobidp.common.Duration": {
                     "type": [
                            "number",
                            "string"
                     ],
                     "pattern": "^P([0-9]+D)?T([0-9]+H)?([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?$"
              },
              "mobidp.common.Geometry": {
                     "description": "My Geometry",
                     "oneOf": [
                            {
                                   "$ref": "#/definitions/mobidp.common.Point"
                            },
                            {
                                   "$ref": "#/definitions/mobidp.common.MultiPoint"
                            },
                            {
                                   "$ref": "#/definitions/mobidp.common.LineString"
                            },
                            {
                                   "$ref": "#/definitions/mobidp.common.Polygon"
                            },
                            {
                                   "$ref": "#/definitions/mobidp.common.MultiPolygon"
                            }
                     ]
              },
              "Foo": {
                     "type": "object",
                     "properties": {
                            "a": {
                                   "type": "string"
                            },
                            "b": {
                                   "type": "number"
                            }
                     }
              },
              "Bar": {
                     "type": "object",
                     "allOf": [
                            {
                                   "$ref": "#/definitions/Foo"
                            }
                     ],
                     "properties": {
                            "c": {
                                   "$ref": "#/definitions/mobidp.adapters.Duration"
                            }
                     }
              },
              "Baz": {
                     "type": "array",
                     "items": {
                            "type": "object",
                            "additionalProperties": {
                                   "$ref": "#/definitions/mobidp.common.String"
                            }
                     }
              },
              "mobidp.common.Decimal": {
                     "description": "Decimal number",
                     "type": "number"
              },
              "number-foo": {
                     "title": "Foo",
                     "type": "number"
              },
              "number-bar": {
                     "title": "Bar",
                     "type": "number"
              },
              "number-baz": {
                     "title": "Baz",
                     "allOf": [
                            {
                                   "$ref": "#/definitions/mobidp.common.Decimal"
                            }
                     ]
              }
       }
}
