                     "type": "array",
                     "items": {
                            "type": "object",
                            "properties": {
                                   "@type": {
                                          "$ref": "#/definitions/mobidp.common.String"
                                   },
                                   "key": {
                                          "$ref": "#/definitions/mobidp.common.String"
                                   },
                                   "value": {
